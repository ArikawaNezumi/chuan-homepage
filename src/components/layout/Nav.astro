---
import site from "@/config/site";
import { Icon } from "astro-icon/components";

interface Props {
  isWriting?: boolean;
}
const { isWriting = false } = Astro.props;

const currentPath = Astro.url.pathname;
---

<nav
  class="no-scrollbar flex flex-1 flex-col gap-2 overflow-x-visible md:gap-4"
>
  {
    site.navigation.map((item) => {
      const isActive =
        currentPath === item.href ||
        (item.href !== "/" && currentPath.startsWith(item.href));
      const navId = item.href.replace(/\//g, "") || "home";
      return (
        <a
          href={item.href}
          class:list={[
            "group flex w-full items-center justify-between rounded-2xl border border-transparent px-4 py-2.5 transition-all md:min-w-0 md:py-4",
            isWriting ? "md:px-3" : "",
            isActive
              ? "border-primary/20 bg-primary/10 md:hover:border-primary/20 md:hover:bg-primary/15"
              : "hover:bg-muted/50",
          ]}
          transition:name={`nav-${navId}`}
        >
          <div class="flex flex-col">
            <span
              class:list={[
                "font-bold",
                isWriting ? "text-sm md:text-xs" : "text-sm",
                isActive
                  ? "text-primary"
                  : "text-muted-foreground group-hover:text-primary",
              ]}
            >
              {item.name}
            </span>
            <span
              class:list={[
                "text-[10px] tracking-widest uppercase",
                isActive ? "text-primary/60" : "text-muted-foreground/50",
              ]}
            >
              {item.subtitle}
            </span>
          </div>

          {!isWriting &&
            (isActive ? (
              <span class="hidden text-primary md:block">
                <Icon name="mdi:arrow-right" />
              </span>
            ) : (
              <span class="hidden -translate-x-2 text-primary opacity-0 transition-all group-hover:translate-x-0 group-hover:opacity-100 md:block">
                <Icon name="mdi:arrow-right" />
              </span>
            ))}
        </a>
      );
    })
  }
</nav>
