---
import site from "@/config/site";
import Nav from "./Nav.astro";
import ThemeToggle from "./ThemeToggle.astro";
import { Icon } from "astro-icon/components";
import Brand from "./Brand.astro";
import SearchModal from "../blocks/SearchModal.astro";
import SearchBox from "./SearchBox.astro";

const pathname = Astro.url.pathname;
const isWriting = pathname.startsWith("/posts");
---

<aside
  class:list={[
    "flex w-full flex-col border-b border-border bg-muted/20 md:border-r md:border-b-0",
    isWriting ? "p-6 md:w-[14%] md:p-6" : "p-6 md:w-[28%] md:p-10"
  ]}
  data-pagefind-ignore="all"
  transition:name="sidebar"
>
  <Brand isWriting={isWriting} />

  <SearchBox isWriting={isWriting} />

  <Nav isWriting={isWriting} />

  {isWriting ? (

    <div class="mt-6 flex flex-col items-center gap-4 md:mt-auto md:pt-6">
      <div class="grid grid-cols-2 gap-3 text-muted-foreground/60">
        {
          site.social.map((item) => (
            <a
              href={item.href}
              class="flex items-center justify-center cursor-pointer transition-colors hover:text-primary p-1"
              aria-label={item.name}
              target="_blank"
              rel="noopener noreferrer"
              transition:name={`social-${item.name.toLowerCase()}`}
            >
              <Icon name={item.icon} size={22} />
            </a>
          ))
        }
      </div>
      <div transition:name="theme-toggle">
        <ThemeToggle />
      </div>
    </div>
  ) : (

    <div class="mt-8 flex items-center justify-between md:mt-14">
      <div class="flex gap-4 text-muted-foreground/60">
        {
          site.social.map((item) => (
            <a
              href={item.href}
              class="cursor-pointer transition-colors hover:text-primary"
              aria-label={item.name}
              target="_blank"
              rel="noopener noreferrer"
              transition:name={`social-${item.name.toLowerCase()}`}
            >
              <Icon name={item.icon} size={24} />
            </a>
          ))
        }
      </div>

      <div transition:name="theme-toggle">
        <ThemeToggle />
      </div>
    </div>
  )}

  <SearchModal />
</aside>
